script = ExtResource("1_qkqcp")
name = "“Ang Aking Kababata” (To My Fellow Youth) Poem"
description = "An early poem attributed to Rizal from when he was a child. It expresses the importance of loving one's own language and culture. At a tender age, his patriotic sentiment began to emerge."
