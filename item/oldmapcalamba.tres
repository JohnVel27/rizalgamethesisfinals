[resource]
script = ExtResource("1_nn1a4")
name = "Old Map of Calamba"
description = "An old map of the town of Calamba that Rizal often gazed at when he was a child. Here, he saw the fields, homes, and land that the farmers toiled over. At a young age, he began to notice the unequal treatment of Filipinos in their own land."
