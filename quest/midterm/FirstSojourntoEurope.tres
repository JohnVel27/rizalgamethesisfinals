[resource]
script = ExtResource("2_4fj8y")
title = "First Sojourn to Europe"
description = "In 1882, José Rizal secretly leaves the Philippines with the help of Paciano Rizal to study in Europe. At the Port of Manila, he bids farewell to his family, determined to gain knowledge for his country. As he boards the ship to Spain, Rizal begins a journey that will shape his role in awakening the nation."
steps = Array[String](["Talk to Paciano"])
metadata/_custom_type_script = "uid://datfl3b15axlx"
