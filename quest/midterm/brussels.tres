[resource]
script = ExtResource("2_6kt72")
title = "Rizal in Brussels"
description = "In Brussels, José Rizal continues his reformist work and begins writing a darker novel reflecting the struggles of Filipinos. Surrounded by fellow reformists, he expresses the need to expose deeper injustices to awaken the nation. Despite pressure from Spanish officials, Rizal remains determined to use his writings to inspire change and reveal the truth."
steps = Array[String](["Go to Brussel Apartment", "Talk to filipino reformist"])
metadata/_custom_type_script = "uid://datfl3b15axlx"
