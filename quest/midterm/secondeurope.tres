[resource]
script = ExtResource("2_8jwjw")
title = "Second Sojourn to Europe (1888)"
description = "In 1888, José Rizal leaves the Philippines once again to protect his family and continue his mission abroad. In Europe, he joins fellow reformists like Marcelo H. del Pilar and Graciano López Jaena in advocating for change through the Propaganda Movement. Together, they use their writings to fight for equality, justice, and recognition of Filipino rights under Spanish rule."
steps = Array[String](["Talk to Paciano"])
metadata/_custom_type_script = "uid://datfl3b15axlx"
